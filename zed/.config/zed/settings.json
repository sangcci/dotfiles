// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ui_font_family": ".SystemUIFont",
  "agent_servers": {
    "pi-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "dock": "right",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "buffer_line_height": {
    "custom": 1.7000000476837158,
  },
  "buffer_font_weight": 200.0,
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "which_key": {
    "enabled": true,
  },
  "vim": {
    "use_system_clipboard": "always",
  },
  "formatter": "language_server",
  "ui_font_size": 15.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "macOS Classic Dark",
  },
  "lsp": {
    "jdtls": {
      "settings": {
        "java_home": "~/.sdkman/candidates/java/25.0.1-tem",
        "lombok_support": true,
        "jdk_auto_download": false,
        // Controls when to check for updates for JDTLS, Lombok, and Debugger
        // - "always" (default): Always check for and download the latest version
        // - "once": Check for updates only if no local installation exists
        // - "never": Never check for updates, only use existing local installations (errors if missing)
        //
        // Note: Invalid values will default to "always"
        // If custom paths (below) are provided, check_updates is IGNORED for that component
        "check_updates": "always",
      },
    },
  },
}

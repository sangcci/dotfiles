#!/bin/sh
set -e

MASON_COMMITLINT="$HOME/.local/share/nvim/mason/bin/commitlint"

if command -v commitlint > /dev/null 2>&1; then
  COMMITLINT="commitlint"
elif [ -x "$MASON_COMMITLINT" ]; then
  COMMITLINT="$MASON_COMMITLINT"
else
  echo "commitlint not found. Install via Mason (:MasonInstall commitlint) or npm install -g @commitlint/cli"
  exit 1
fi

for f in commitlint.config.js commitlint.config.cjs commitlint.config.mjs \
          .commitlintrc .commitlintrc.js .commitlintrc.cjs \
          .commitlintrc.json .commitlintrc.yml .commitlintrc.yaml; do
  if [ -f "$f" ]; then
    $COMMITLINT --edit "$1"
    exit $?
  fi
done

$COMMITLINT --config "$HOME/.config/commitlint/config.cjs" --edit "$1"

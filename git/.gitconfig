[user]
	name = sangcci
	email = pshsh910@gmail.com
[core]
	excludesfile = /Users/sangcci/.gitignore_global
	pager = delta
[init]
	defaultBranch = main
[pull]
	rebase = true
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
	side-by-side = true
[merge]
    conflictStyle = zdiff3
